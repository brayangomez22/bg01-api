# BG-01 API — environment
# Copy to .env and fill in. Never commit .env.

# HTTP server
PORT=8080

# SQLite file path
DB_PATH=bg01.db

# Single admin auth.
# Generate the hash with: go run ./cmd/hashpw 'your-password'
ADMIN_PASSWORD_HASH=
# Random secret for signing session cookies (e.g. `openssl rand -base64 32`)
SESSION_SECRET=

# Admin panel origin allowed by CORS.
# Local dev: the Vite dev server, http://localhost:5173
# Production: https://brayangomez.dev
ALLOWED_ORIGIN=http://localhost:5173

# Set to false for local HTTP development so cookies are sent over http://localhost.
# Production (HTTPS) must keep this true.
COOKIE_SECURE=true

# Publishing: POST /admin/publish fires a repository_dispatch to rebuild the
# static site. Leave empty to disable (endpoint returns 503).
# Repo that holds the portfolio + deploy workflow:
PUBLISH_REPO=brayangomez22/bg01-station
# Fine-grained PAT with "Contents: read & write" (or Actions) on PUBLISH_REPO:
GITHUB_DISPATCH_TOKEN=
