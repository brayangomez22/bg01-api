# BG-01 API — environment
# Copy to .env and fill in. Never commit .env.

# HTTP server
PORT=8080

# SQLite file path
DB_PATH=bg01.db

# Single admin auth.
# Generate the hash with: go run ./cmd/hashpw 'your-password'
ADMIN_PASSWORD_HASH=
# Random secret for signing session cookies (e.g. `openssl rand -base64 32`)
SESSION_SECRET=

# Admin panel origin allowed by CORS (leave empty for export-only / server-side use)
ALLOWED_ORIGIN=

# Set to false for local HTTP development so cookies are sent over http://localhost
COOKIE_SECURE=true
